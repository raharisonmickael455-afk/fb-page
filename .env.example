# Variables d'environnement pour Render
# Ajoutez ces variables dans le Dashboard Render

# Port (Render l'attribue automatiquement, mais à avoir en local)
PORT=5000

# Mode environnement
FLASK_ENV=production

# Clé secrète (À CHANGER avant production!)
SECRET_KEY=votre-clé-secrète-très-longue-à-changer
# Configuration CORS
# =========================
CORS_ORIGINS=https://votredomaine.com,https://www.votredomaine.com

# =========================
# Configuration Email (optionnel)
# =========================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_password
MAIL_USE_TLS=True

# =========================
# Configuration Sécurité
# =========================
ALLOW_REGISTRATION=True
PASSWORD_MIN_LENGTH=6
MAX_LOGIN_ATTEMPTS=5

# =========================
# Configuration Logging
# =========================
LOG_LEVEL=INFO
LOG_FILE=app.log

# =========================
# Configuration API
# =========================
API_TIMEOUT=30
RATE_LIMIT=100/hour
